{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["pearstarter"],
  "ios": {
    "iosModuleName": "PearStarter"
  },
  "android": {
    "androidNamespace": ["pearstarter"],
    "androidCxxLibName": "PearStarter"
  },
  "autolinking": {
    "PearStarterPaths": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPearStarterPaths"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPearStarterPaths"
      }
    },
    "PearStarterRoll": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPearStarterRoll"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPearStarterRoll"
      }
    },
    "PearStarterBytes": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridPearStarterBytes"
      }
    },
    "PearStarterEmbed": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPearStarterEmbed"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPearStarterEmbed"
      }
    }
  },
  "ignorePaths": ["node_modules"]
}
